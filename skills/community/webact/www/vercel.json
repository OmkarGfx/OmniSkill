{
  "rewrites": [
    { "source": "/v1/:path*", "destination": "/api/v1/:path*" },
    { "source": "/download/:path*", "destination": "/api/download/:path*" },
    { "source": "/install", "destination": "/api/script?name=install" },
    { "source": "/uninstall", "destination": "/api/script?name=uninstall" }
  ],
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "(?!webact\\.space).*" }],
      "destination": "https://webact.space/:path",
      "statusCode": 301
    }
  ]
}
